# =============================================================================
# VitalFlow — LOCAL development env template
# =============================================================================
# Copy this file to `.env.local` in the repo root and fill in the values.
# Do NOT commit `.env` / `.env.local` — they are git-ignored.
#
# For staging/production, do NOT use this file. Configure variables in the
# Vercel project environments; this repo ships `.env.staging.example` and
# `.env.production.example` as the canonical lists of required keys per tier.
# =============================================================================

# --- Runtime --------------------------------------------------------------- #
NODE_ENV=development
VITALFLOW_ENV=local
LOG_LEVEL=debug

# When set to "true", the web app bypasses Supabase auth and uses a stub
# session with practice_owner + physician roles. Useful for UI work before
# you've seeded a real user. NEVER set in staging or production.
VITALFLOW_DEV_SESSION=false

# --- Supabase (vitalflow-dev or local via `supabase start`) --------------- #
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...local...anon
SUPABASE_SERVICE_ROLE_KEY=eyJ...local...service-role
SUPABASE_JWT_SECRET=super-secret-local-jwt
SUPABASE_PROJECT_REF=local

# --- Auth ----------------------------------------------------------------- #
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_COOKIE_DOMAIN=localhost
AUTH_SESSION_TTL_SECONDS=3600

# --- AI providers (leave blank unless actively developing AI paths) ------- #
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_DEFAULT_MODEL=claude-opus-4-6
AI_EMBEDDING_MODEL=text-embedding-3-small

# --- Monetization / Stripe (ALWAYS test keys locally) --------------------- #
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Notifications (sandbox providers only) ------------------------------- #
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Integrations (sandbox endpoints only) -------------------------------- #
FHIR_BASE_URL=
HL7_MLLP_HOST=
HL7_MLLP_PORT=

# --- Observability (dev-scoped Sentry/PostHog projects) ------------------- #
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=vitalflow
SENTRY_PROJECT=vitalflow-dev

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Feature flags -------------------------------------------------------- #
NEXT_PUBLIC_FLAGS_CLIENT_KEY=

# --- Tenancy -------------------------------------------------------------- #
TENANT_ROUTING_MODE=subdomain   # subdomain | path | header
DEFAULT_TENANT_SLUG=demo
