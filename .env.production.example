# =============================================================================
# VitalFlow — PRODUCTION env mirror
# =============================================================================
# This file is NOT loaded at runtime. It is the canonical list of keys that
# must be configured in the "Production" environment of each Vercel project
# before a production deploy is approved.
#
# ALL values must be distinct from staging. No shared secrets across tiers.
# Rotate every 90 days; immediately on any suspected compromise or departure.
#
# Access to production secrets is restricted to members of the `ops-production`
# GitHub team and requires an approved `production` environment deployment
# review in GitHub Actions.
# =============================================================================

# --- Runtime --------------------------------------------------------------- #
NODE_ENV=production
VITALFLOW_ENV=production
LOG_LEVEL=info

# --- Supabase (dedicated `vitalflow-prod` project; PITR enabled) ---------- #
NEXT_PUBLIC_SUPABASE_URL=https://<prod-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<from Supabase → Project Settings → API>
SUPABASE_SERVICE_ROLE_KEY=<secret — rotate 90d; audited>
SUPABASE_JWT_SECRET=<secret — rotate 90d; audited>
SUPABASE_PROJECT_REF=<prod-project-ref>

# --- Auth ----------------------------------------------------------------- #
AUTH_SECRET=<32-byte base64 — UNIQUE to production; rotate 90d>
AUTH_COOKIE_DOMAIN=vitalflow.health
AUTH_SESSION_TTL_SECONDS=3600

# --- AI providers (production keys; separate billing; BAA with provider) -- #
OPENAI_API_KEY=<prod key; BAA signed>
ANTHROPIC_API_KEY=<prod key; BAA signed>
AI_DEFAULT_MODEL=claude-opus-4-6
AI_EMBEDDING_MODEL=text-embedding-3-small

# --- Monetization / Stripe (LIVE KEYS — production only) ------------------ #
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- Notifications (production senders; BAA in place) --------------------- #
RESEND_API_KEY=<prod key>
TWILIO_ACCOUNT_SID=<prod SID>
TWILIO_AUTH_TOKEN=<prod token>
TWILIO_FROM_NUMBER=<A2P-registered number>

# --- Integrations (production endpoints; BAA in place) -------------------- #
FHIR_BASE_URL=https://fhir.partner.example.com/fhir
HL7_MLLP_HOST=mllp.partner.example.com
HL7_MLLP_PORT=2575

# --- Observability (prod-scoped Sentry + PostHog projects; 90d retention) - #
SENTRY_DSN=<prod project DSN>
SENTRY_AUTH_TOKEN=<CI-only; release creation>
SENTRY_ORG=vitalflow
SENTRY_PROJECT=vitalflow

NEXT_PUBLIC_POSTHOG_KEY=<prod project key>
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Feature flags -------------------------------------------------------- #
NEXT_PUBLIC_FLAGS_CLIENT_KEY=<prod client key>

# --- Tenancy -------------------------------------------------------------- #
TENANT_ROUTING_MODE=subdomain
DEFAULT_TENANT_SLUG=                # no default — tenant must be explicit
