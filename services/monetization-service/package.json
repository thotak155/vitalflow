{
  "name": "@vitalflow/monetization-service",
  "version": "0.1.0",
  "private": true,
  "description": "Subscriptions, plan metering, usage billing, trials, dunning, Stripe webhook handlers.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@vitalflow/integrations": "workspace:*",
    "@vitalflow/shared-utils": "workspace:*",
    "@vitalflow/types": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitalflow/config": "workspace:*",
    "eslint": "^9.11.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
