{
  "name": "@vitalflow/web",
  "version": "0.1.0",
  "private": true,
  "description": "VitalFlow — unified role-aware web application (provider, admin, patient).",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
