    "@vitalflow/auth": "workspace:*",
    "@vitalflow/clinical-service": "workspace:*",
    "@vitalflow/erp-service": "workspace:*",
    "@vitalflow/integrations": "workspace:*",
    "@vitalflow/monetization-service": "workspace:*",
    "@vitalflow/notification-service": "workspace:*",
    "@vitalflow/shared-utils": "workspace:*",
    "@vitalflow/types": "workspace:*",
    "@vitalflow/ui": "workspace:*",
    "@vitalflow/workflow-service": "workspace:*",
    "@vitalflow/workflows": "workspace:*",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
