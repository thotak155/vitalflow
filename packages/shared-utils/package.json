{
  "name": "@vitalflow/shared-utils",
  "version": "0.1.0",
  "private": true,
  "description": "Framework-agnostic utilities: logging, errors, result types, date/money helpers, PHI redaction.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./logger": "./src/logger.ts",
    "./errors": "./src/errors.ts",
    "./result": "./src/result.ts",
    "./phi": "./src/phi.ts"
  },
  "files": ["src", "dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitalflow/config": "workspace:*",
    "eslint": "^9.11.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
