{
  "name": "@vitalflow/integrations",
  "version": "0.1.0",
  "private": true,
  "description": "Third-party adapters: FHIR, HL7v2, e-prescribing, labs, clearinghouses, Stripe, Twilio, Resend.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./fhir": "./src/fhir/index.ts",
    "./hl7": "./src/hl7/index.ts",
    "./stripe": "./src/stripe/index.ts",
    "./twilio": "./src/twilio/index.ts",
    "./resend": "./src/resend/index.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@vitalflow/shared-utils": "workspace:*",
    "@vitalflow/types": "workspace:*",
    "resend": "^4.0.0",
    "stripe": "^17.2.0",
    "twilio": "^5.3.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitalflow/config": "workspace:*",
    "eslint": "^9.11.1",
    "typescript": "^5.6.2"
  }
}
