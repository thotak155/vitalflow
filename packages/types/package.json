{
  "name": "@vitalflow/types",
  "version": "0.1.0",
  "private": true,
  "description": "Canonical types, Zod schemas, and Supabase-generated DB types for VitalFlow.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/index.ts",
    "./clinical": "./src/clinical/index.ts",
    "./erp": "./src/erp/index.ts",
    "./workflow": "./src/workflow/index.ts",
    "./tenancy": "./src/tenancy/index.ts",
    "./ai": "./src/ai/index.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "generate": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF > src/db/supabase.generated.ts",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitalflow/config": "workspace:*",
    "eslint": "^9.11.1",
    "typescript": "^5.6.2"
  }
}
