{
  "name": "@vitalflow/analytics",
  "version": "0.1.0",
  "private": true,
  "description": "Product analytics abstraction (PostHog + server-side event pipeline) with typed event catalog.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./events": "./src/events.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@vitalflow/types": "workspace:*",
    "posthog-js": "^1.165.0",
    "posthog-node": "^4.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@vitalflow/config": "workspace:*",
    "eslint": "^9.11.1",
    "react": "^19.0.0",
    "typescript": "^5.6.2"
  }
}
