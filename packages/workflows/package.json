{
  "name": "@vitalflow/workflows",
  "version": "0.1.0",
  "private": true,
  "description": "Workflow primitives: state machines, task orchestration, human-in-the-loop steps, SLAs.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./state-machine": "./src/state-machine.ts",
    "./definitions": "./src/definitions/index.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@vitalflow/shared-utils": "workspace:*",
    "@vitalflow/types": "workspace:*",
    "xstate": "^5.18.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitalflow/config": "workspace:*",
    "eslint": "^9.11.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
