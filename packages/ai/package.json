{
  "name": "@vitalflow/ai",
  "version": "0.1.0",
  "private": true,
  "description": "LLM client abstractions, prompt templates, guardrails, embeddings, and audit logging for VitalFlow AI.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./providers": "./src/providers/index.ts",
    "./guardrails": "./src/guardrails/index.ts",
    "./prompts": "./src/prompts/index.ts"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@vitalflow/shared-utils": "workspace:*",
    "@vitalflow/types": "workspace:*",
    "openai": "^4.67.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitalflow/config": "workspace:*",
    "eslint": "^9.11.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
