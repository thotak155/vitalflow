{
  "name": "@vitalflow/config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared build/lint/style configuration for VitalFlow (tsconfig, eslint, prettier, tailwind presets).",
  "type": "module",
  "exports": {
    "./tsconfig/base.json": "./tsconfig/base.json",
    "./tsconfig/nextjs.json": "./tsconfig/nextjs.json",
    "./tsconfig/react-library.json": "./tsconfig/react-library.json",
    "./tsconfig/node.json": "./tsconfig/node.json",
    "./eslint/base.js": "./eslint/base.js",
    "./eslint/nextjs.js": "./eslint/nextjs.js",
    "./eslint/react.js": "./eslint/react.js",
    "./eslint/node.js": "./eslint/node.js",
    "./tailwind/preset": "./tailwind/preset.ts"
  },
  "files": [
    "tsconfig",
    "eslint",
    "tailwind"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf node_modules .turbo"
  },
  "dependencies": {
    "@eslint/js": "^9.11.1",
    "@next/eslint-plugin-next": "^15.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.10.0",
    "tailwindcss": "^3.4.13"
  },
  "devDependencies": {
    "eslint": "^9.11.1",
    "typescript": "^5.6.2"
  }
}
